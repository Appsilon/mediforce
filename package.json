{
  "name": "mediforce",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "tsc -b --noEmit",
    "dev": "pnpm --filter @mediforce/platform-ui dev",
    "dev:mock": "pnpm --filter @mediforce/platform-ui dev:mock",
    "dev:no-docker": "ALLOW_LOCAL_AGENTS=true pnpm --filter @mediforce/platform-ui dev",
    "dev:full": "docker compose up -d redis container-worker && REDIS_URL=redis://localhost:6379 pnpm --filter @mediforce/platform-ui dev",
    "dev:full:down": "docker compose down",
    "emulators": "pnpm --filter @mediforce/platform-ui emulators",
    "worker": "REDIS_URL=redis://localhost:6379 tsx packages/container-worker/src/worker-entry.ts",
    "redis": "docker run --rm -p 6379:6379 redis:7-alpine",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "pnpm --filter @mediforce/platform-ui test:e2e",
    "test:e2e:api": "pnpm --filter @mediforce/platform-ui test:e2e --project=api",
    "test:e2e:ui": "pnpm --filter @mediforce/platform-ui test:e2e --project=authenticated",
    "test:e2e:record": "pnpm --filter @mediforce/platform-ui test:e2e:record",
    "test:watch": "vitest",
    "test:affected": "vitest run --changed",
    "test:coverage": "vitest run --coverage",
    "test:external": "pnpm --filter @mediforce/platform-ui test:external",
    "seed": "pnpm --filter @mediforce/platform-ui seed:dev",
    "start": "pnpm --filter @mediforce/platform-ui start",
    "migrate:handles": "tsx scripts/migrate-user-handles.ts",
    "link:cli": "python3 scripts/link-cli.py"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "protobufjs",
      "msgpackr-extract",
      "@firebase/util"
    ],
    "overrides": {
      "axios": ">=1.15.0",
      "protobufjs": "8.0.1",
      "hono": "4.12.18",
      "@hono/node-server": "2.0.1",
      "fast-xml-parser": "5.7.3",
      "node-forge": "1.4.0",
      "follow-redirects": "1.16.0",
      "brace-expansion": "5.0.5",
      "@tootallnate/once": "3.0.1",
      "next": "16.2.5",
      "vite": "8.0.11"
    },
    "minimumReleaseAgeExclude": [
      "axios",
      "protobufjs",
      "hono"
    ]
  },
  "devDependencies": {
    "@mediforce/cli": "workspace:*",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.4",
    "tsx": "latest",
    "typescript": "~6.0.0",
    "vite": "8.0.11",
    "vitest": "^4.1.4"
  }
}
