# Firebase configuration for platform-ui
# Copy this to .env.local and fill in your Firebase project values
# Get these from: Firebase Console > Project Settings > General > Your apps

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
PLATFORM_API_KEY=
# Dedicated key for admin-only endpoints (/api/admin/oauth-providers/**).
# Keeps admin mutations off the regular PLATFORM_API_KEY surface. Leave
# empty to require a Firebase owner/admin role instead.
PLATFORM_ADMIN_API_KEY=
# HMAC key used to sign OAuth state tokens. When unset, the server falls
# back to PLATFORM_API_KEY so existing deployments keep working. Recommended
# to set a dedicated 32+ byte random string so state signing can be rotated
# independently of the platform API key.
OAUTH_STATE_SECRET=
APP_BASE_URL=
NAMESPACE=

# Command palette → ticket creation (optional)
# Personal access token with `repo` scope for the target repo, so the
# "New ticket" command in the command palette can open GitHub issues.
GITHUB_TOKEN=
GITHUB_REPO=appsilon/mediforce
