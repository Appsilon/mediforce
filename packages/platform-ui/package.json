{
  "name": "@mediforce/platform-ui",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev -p 9003",
    "dev:test": "NEXT_PUBLIC_USE_EMULATORS=true NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-mediforce next dev -p 9003",
    "build": "rm -rf .next && next build",
    "start": "next start -p ${PORT:-3000}",
    "typecheck": "tsc --noEmit",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:auth": "NEXT_PUBLIC_USE_EMULATORS=true playwright test",
    "test:e2e:auth:headed": "NEXT_PUBLIC_USE_EMULATORS=true playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:record": "fuser -k 9007/tcp 2>/dev/null || lsof -ti:9007 | xargs kill 2>/dev/null; NEXT_PUBLIC_USE_EMULATORS=true E2E_RECORD=true playwright test --project=authenticated --workers=1",
    "test:e2e:gif": "fuser -k 9007/tcp 2>/dev/null || lsof -ti:9007 | xargs kill 2>/dev/null; NEXT_PUBLIC_USE_EMULATORS=true E2E_RECORD=true playwright test --project=authenticated --workers=1 && python3 scripts/e2e-to-gif.py",
    "test:e2e:check-gifs": "python3 scripts/check-gif-freshness.py",
    "emulators": "bash scripts/start-emulators.sh",
    "deploy": "pnpm build && firebase deploy --only hosting"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@hookform/resolvers": "^5.0.0",
    "@mediforce/agent-runtime": "workspace:*",
    "@mediforce/platform-core": "workspace:*",
    "@mediforce/platform-infra": "workspace:*",
    "@mediforce/supply-intelligence-plugins": "workspace:*",
    "@mediforce/workflow-engine": "workspace:*",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@xyflow/react": "^12.10.1",
    "bullmq": "^5.71.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "date-fns": "^4.0.0",
    "firebase": "^11.9.1",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.0.0",
    "next": "^15.5.12",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@mediforce/agent-queue": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.0",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.0"
  }
}
