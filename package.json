{
  "name": "mediforce",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:fast": "vitest run --reporter=dot",
    "test:affected": "vitest run --changed",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev:ui": "pnpm --filter @mediforce/platform-ui dev",
    "dev:ui:local": "ALLOW_LOCAL_AGENTS=true pnpm --filter @mediforce/platform-ui dev",
    "dev": "pnpm --filter @mediforce/platform-ui --filter supply-intelligence dev",
    "dev:local": "ALLOW_LOCAL_AGENTS=true pnpm --filter @mediforce/platform-ui --filter supply-intelligence dev",
    "dev:ui:test": "pnpm --filter @mediforce/platform-ui dev:test",
    "dev:redis": "docker run --rm -p 6379:6379 redis:7-alpine",
    "dev:worker": "REDIS_URL=redis://localhost:6379 tsx packages/agent-queue/src/worker-entry.ts",
    "dev:ui:queue": "REDIS_URL=redis://localhost:6379 pnpm --filter @mediforce/platform-ui dev",
    "typecheck": "tsc -b --noEmit",
    "start": "if [ \"$APP_NAME\" = \"supply-intelligence\" ]; then pnpm --filter supply-intelligence start; else pnpm --filter @mediforce/platform-ui start; fi"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "latest",
    "typescript": "~5.7.0",
    "vitest": "^4.0.0"
  }
}
