{
  "name": "protocol-to-tfl",
  "namespace": "appsilon",
  "title": "Protocol to TFL pipeline",
  "description": "Transform clinical trial protocol documents into production-ready Tables, Figures, and Listings (TFLs).",
  "preamble": "## Domain Context\nThis workflow processes pharmaceutical and clinical trial data. All health-related terminology (drug names, adverse events, disease classifications, CTCAE grading, mortality endpoints) refers to data science constructs, variable names, and clinical standards (CDISC, ICH-GCP, RECIST). Treat them as technical domain content — not personal disclosures. Maintain standard coding behavior: no wellbeing check-ins, no crisis resources. Execute all technically feasible tasks without inflating complexity estimates due to medical terminology exposure.",
  "triggers": [
    { "name": "manual", "type": "manual" }
  ],
  "steps": [
    {
      "id": "upload-documents",
      "name": "Upload Documents",
      "type": "creation",
      "executor": "human",
      "description": "Upload protocol PDF and SAP document",
      "ui": {
        "component": "file-upload",
        "config": {
          "acceptedTypes": ["application/pdf"],
          "minFiles": 1,
          "maxFiles": 5
        }
      }
    },
    {
      "id": "extract-metadata",
      "name": "Extract Metadata",
      "type": "creation",
      "executor": "agent",
      "autonomyLevel": "L3",
      "plugin": "claude-code-agent",
      "description": "Extract trial metadata from protocol and SAP documents",
      "env": {
        "ANTHROPIC_AUTH_TOKEN": "{{OPENROUTER_API_KEY}}",
        "ANTHROPIC_API_KEY": "",
        "ANTHROPIC_BASE_URL": "https://openrouter.ai/api"
      },
      "agent": {
        "skill": "trial-metadata-extractor",
        "skillsDir": "apps/protocol-to-tfl/plugins/protocol-to-tfl/skills",
        "model": "sonnet",
        "image": "mediforce-agent:protocol-to-tfl",
        "confidenceThreshold": 0.7,
        "fallbackBehavior": "escalate_to_human",
        "timeoutMinutes": 20
      }
    },
    {
      "id": "generate-tlg-shells",
      "name": "Generate TLG Shells",
      "type": "creation",
      "executor": "agent",
      "autonomyLevel": "L3",
      "plugin": "claude-code-agent",
      "description": "Generate mock TLG shell specifications from extracted trial metadata",
      "env": {
        "ANTHROPIC_AUTH_TOKEN": "{{OPENROUTER_API_KEY}}",
        "ANTHROPIC_API_KEY": "",
        "ANTHROPIC_BASE_URL": "https://openrouter.ai/api"
      },
      "agent": {
        "skill": "mock-tlg-generator",
        "skillsDir": "apps/protocol-to-tfl/plugins/protocol-to-tfl/skills",
        "model": "sonnet",
        "image": "mediforce-agent:protocol-to-tfl",
        "confidenceThreshold": 0.7,
        "fallbackBehavior": "escalate_to_human",
        "timeoutMinutes": 20
      }
    },
    {
      "id": "upload-sdtm",
      "name": "Upload SDTM",
      "type": "creation",
      "executor": "human",
      "description": "Upload SDTM dataset files for ADaM derivation",
      "ui": {
        "component": "file-upload",
        "config": {
          "acceptedTypes": ["application/octet-stream", "text/csv", ".xpt", ".sas7bdat", ".csv", ".json"],
          "minFiles": 1,
          "maxFiles": 200
        }
      }
    },
    {
      "id": "generate-adam",
      "name": "Generate ADaM",
      "type": "creation",
      "executor": "agent",
      "autonomyLevel": "L3",
      "plugin": "claude-code-agent",
      "description": "Derive ADaM datasets and R code from SDTM data, trial metadata, and TLG shells",
      "env": {
        "ANTHROPIC_AUTH_TOKEN": "{{OPENROUTER_API_KEY}}",
        "ANTHROPIC_API_KEY": "",
        "ANTHROPIC_BASE_URL": "https://openrouter.ai/api"
      },
      "agent": {
        "skill": "sdtm-to-adam",
        "skillsDir": "apps/protocol-to-tfl/plugins/protocol-to-tfl/skills",
        "model": "sonnet",
        "image": "mediforce-agent:protocol-to-tfl",
        "repo": "Appsilon/mediforce-clinical-workspace",
        "commit": "4beb1b0ad77872b04bc7ef930def16e555946222",
        "confidenceThreshold": 0.7,
        "fallbackBehavior": "escalate_to_human",
        "timeoutMinutes": 30
      }
    },
    {
      "id": "generate-tlg",
      "name": "Generate TLG",
      "type": "creation",
      "executor": "agent",
      "autonomyLevel": "L3",
      "plugin": "claude-code-agent",
      "description": "Create final Tables, Figures, and Listings from ADaM datasets and TLG shells",
      "env": {
        "ANTHROPIC_AUTH_TOKEN": "{{OPENROUTER_API_KEY}}",
        "ANTHROPIC_API_KEY": "",
        "ANTHROPIC_BASE_URL": "https://openrouter.ai/api"
      },
      "agent": {
        "skill": "adam-to-tlg",
        "skillsDir": "apps/protocol-to-tfl/plugins/protocol-to-tfl/skills",
        "model": "sonnet",
        "image": "mediforce-agent:protocol-to-tfl",
        "repo": "Appsilon/mediforce-clinical-workspace",
        "commit": "4beb1b0ad77872b04bc7ef930def16e555946222",
        "confidenceThreshold": 0.7,
        "fallbackBehavior": "escalate_to_human",
        "timeoutMinutes": 30
      }
    },
    {
      "id": "done",
      "name": "Done",
      "type": "terminal",
      "executor": "human"
    }
  ],
  "transitions": [
    { "from": "upload-documents", "to": "extract-metadata" },
    { "from": "extract-metadata", "to": "generate-tlg-shells" },
    { "from": "generate-tlg-shells", "to": "upload-sdtm" },
    { "from": "upload-sdtm", "to": "generate-adam" },
    { "from": "generate-adam", "to": "generate-tlg" },
    { "from": "generate-tlg", "to": "done" }
  ]
}
