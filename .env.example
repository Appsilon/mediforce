# Mediforce Production Environment
# Copy to .env and fill in values.

NEXT_PUBLIC_APP_URL=

# --- Authentication: NextAuth / Auth.js v5 (ADR-0002) ---
# Firebase Auth is gone; identity lives in Postgres (auth_* tables). Firestore
# (ADR-0001) and Storage (ADR-0003) were already off Firebase, so no
# NEXT_PUBLIC_FIREBASE_* vars remain.
#
# Session signing secret (required). Generate with: openssl rand -hex 32
AUTH_SECRET=
# Full public URL of the deployment, e.g. https://mediforce.acme.com. Only
# required when NextAuth cannot auto-detect it (behind a reverse proxy).
AUTH_URL=
# Google OAuth provider — parity with the old "Sign in with Google".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Set to "true" to enable email + password sign-in via /api/auth/password-login.
ENABLE_PASSWORD_AUTH=
# Set to "true" to enable magic-link (passwordless) sign-in via the Auth.js Email
# provider. Requires an email provider (MAILGUN_* or SMTP_*) configured and
# MEDIFORCE_DISABLE_EMAIL unset. Gives password-only users a first-password /
# recovery path; links reach only existing allowlisted users (ADR-0002 §4).
ENABLE_MAGIC_LINK=
# Firebase migrate-on-login (ADR-0002 Gap 2): verify a migrated user's Firebase
# scrypt password at sign-in and rehash it to bcrypt. Set ALL FOUR or none —
# a partial set fails loud at login. Pull them once from the Firebase console
# (Authentication → users menu → "Password hash parameters") for the project.
FIREBASE_SCRYPT_SIGNER_KEY=
FIREBASE_SCRYPT_SALT_SEPARATOR=
FIREBASE_SCRYPT_ROUNDS=
FIREBASE_SCRYPT_MEM_COST=
# Comma-separated email-domain allowlist enforced in the signIn callback across
# ALL providers (ADR-0002 §4a), e.g. `appsilon.com`. Unset = no restriction.
# With Google enabled this is what stops any Google account on earth signing in.
ALLOWED_EMAIL_DOMAINS=
# Customer SSO (OIDC) — one IdP per deployment (Keycloak / Entra / Okta /
# generic OIDC). Dormant until OIDC_ISSUER is set.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISPLAY_NAME=

# --- Platform API ---
PLATFORM_API_KEY=

# --- Agent secrets (injected into Docker containers via -e flags) ---
DOCKER_DEEPSEEK_API_KEY=
DOCKER_OPENROUTER_API_KEY=

# --- Postgres (ADR-0001) ---
DATABASE_URL=

# --- Task attachments (ADR-0003) ---
# Max upload size in bytes; operational disk guard, not a design cap.
# Default 104857600 (100 MiB) when unset.
MEDIFORCE_ATTACHMENT_MAX_BYTES=104857600


# --- Workflow secrets encryption ---
# 32 bytes as 64 hex chars. Generate with: openssl rand -hex 32
# Required by platform-infra/src/crypto/secrets-cipher.ts for encrypting
# workflow secrets at rest. Losing this key makes stored secrets unrecoverable.
SECRETS_ENCRYPTION_KEY=

# --- Server ---
DOMAIN=localhost
# Public-facing base URL of this deployment, used by the server when
# constructing absolute URLs (OAuth redirect_uri, post-callback redirects).
# Required behind any reverse proxy / Docker setup — Next.js standalone
# otherwise reconstructs request.url from the bound container hostname.
APP_BASE_URL=
