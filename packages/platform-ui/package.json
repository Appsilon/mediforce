{
  "name": "@mediforce/platform-ui",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "NEXT_PUBLIC_GIT_SHA=$(git rev-parse --short HEAD) NEXT_PUBLIC_GIT_BRANCH=$(git rev-parse --abbrev-ref HEAD) next dev -p ${PORT:-9003}",
    "dev:mock": "python3 scripts/dev-mock.py",
    "build": "rm -rf .next && next build",
    "build:e2e": "NEXT_PUBLIC_USE_EMULATORS=true NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-mediforce NEXT_PUBLIC_APP_URL=http://localhost:${E2E_PORT:-9007} next build && python3 scripts/e2e_build_gate.py stamp",
    "start:e2e": "python3 scripts/e2e_build_gate.py ensure && MOCK_AGENT=true ALLOW_LOCAL_AGENTS=true MEDIFORCE_DATA_DIR=/tmp/mediforce-e2e-data NEXT_PUBLIC_APP_URL=http://localhost:${E2E_PORT:-9007} NO_PROXY=localhost,127.0.0.1 no_proxy=localhost,127.0.0.1 next start -p ${E2E_PORT:-9007}",
    "start": "next start -p ${PORT:-3000}",
    "typecheck": "tsc --noEmit",
    "test:external": "vitest run --config vitest.config.external.ts",
    "test:action-flows": "vitest run --config vitest.config.action-flows.ts",
    "test:e2e": "NODE_OPTIONS='--conditions=@mediforce/source' NEXT_PUBLIC_USE_EMULATORS=true playwright test",
    "test:e2e:headed": "NODE_OPTIONS='--conditions=@mediforce/source' NEXT_PUBLIC_USE_EMULATORS=true E2E_DEV_SERVER=true playwright test --headed",
    "test:e2e:ui": "NODE_OPTIONS='--conditions=@mediforce/source' E2E_DEV_SERVER=true playwright test --ui",
    "emulators": "bash scripts/start-emulators.sh",
    "seed:dev": "npx tsx scripts/seed-dev-data.ts",
    "deploy": "pnpm build && firebase deploy --only hosting"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "1.11.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@hookform/resolvers": "^5.0.0",
    "@lezer/highlight": "^1.2.3",
    "@mediforce/agent-runtime": "workspace:*",
    "@mediforce/core-actions": "workspace:*",
    "@mediforce/mcp-client": "workspace:*",
    "@mediforce/mediforce-mcp": "workspace:*",
    "@mediforce/platform-api": "workspace:*",
    "@mediforce/platform-core": "workspace:*",
    "@mediforce/platform-infra": "workspace:*",
    "@mediforce/workflow-engine": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.220.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-query-devtools": "^5.100.11",
    "@xyflow/react": "^12.10.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "date-fns": "^4.0.0",
    "firebase": "^12.0.0",
    "firebase-admin": "^14.0.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "lucide-react": "^1.0.0",
    "next": "^16.0.0",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-markdown": "^10.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@mediforce/container-worker": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.1",
    "postgres": "^3.4.9",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  }
}
