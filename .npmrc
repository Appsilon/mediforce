shamefully-hoist=false
strict-peer-dependencies=true

# Supply-chain protection: don't install packages published less than 7 days ago
minimum-release-age=10080
# axios@1.15.0 exempt: security fix for GHSA-3p68-rc4w-qgx5 and GHSA-fvcv-3m26-pcqx
minimum-release-age-exclude[]=axios
# Native binaries are published alongside their parent (next, vite) and may be
# very fresh. Exclude them from the age check.
minimum-release-age-exclude[]=@next/swc-*
minimum-release-age-exclude[]=@rolldown/binding-*
minimum-release-age-exclude[]=@rollup/rollup-*
