rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: admin check via custom claim
    function isAdmin() {
      return request.auth != null && request.auth.token.role == 'admin';
    }

    // Helper: role-scoped read on processInstances (top-level doc has assignedRoles array)
    function hasProcessRole() {
      return request.auth != null
        && request.auth.token.roles is list
        && request.auth.token.roles.hasAny(resource.data.assignedRoles);
    }

    // Helper: subcollection access — must read parent's assignedRoles via get()
    function hasParentProcessRole(instanceId) {
      return request.auth != null
        && get(/databases/$(database)/documents/processInstances/$(instanceId))
           .data.assignedRoles.hasAny([request.auth.token.role]);
    }

    // Audit events: append-only, any authenticated read (BUG-04 fix — role-gated read deferred to Phase 6)
    match /auditEvents/{eventId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['actorId', 'action', 'timestamp', 'entityType', 'entityId', 'inputSnapshot', 'outputSnapshot', 'basis']);
      allow update: if false;
      allow delete: if false;
    }

    // Namespaces: read by authenticated; create/update by authenticated; delete by owner only
    match /namespaces/{handle} {
      allow read: if request.auth != null;
      // Create: if the namespace is personal (has linkedUserId), the user can
      // only create it for themselves — prevents creating a personal namespace
      // on behalf of another uid and then bootstrap-joining it as owner.
      allow create: if request.auth != null
        && (!('linkedUserId' in request.resource.data)
            || request.resource.data.linkedUserId == request.auth.uid);
      // Update: linkedUserId is immutable once set — changing it would let an
      // attacker rebind any namespace to their uid and then self-seed via the
      // personal-bootstrap path in /members.
      allow update: if request.auth != null
        && (!('linkedUserId' in resource.data)
            || resource.data.linkedUserId == request.resource.data.linkedUserId);
      // Only an owner of the namespace may delete it
      allow delete: if request.auth != null
        && get(/databases/$(database)/documents/namespaces/$(handle)/members/$(request.auth.uid)).data.role == 'owner';

      match /members/{memberId} {
        allow read: if request.auth != null;
        // Two create paths:
        //
        //   1. Personal-namespace bootstrap: a user seeds themselves as owner
        //      of their own personal namespace (namespace.linkedUserId ==
        //      auth.uid, memberId == auth.uid, role == 'owner'). This breaks
        //      the circular dep where the "must already be owner/admin" check
        //      below would otherwise block every first-ever write. Cannot be
        //      used to take over anyone else's namespace — linkedUserId pins
        //      the namespace to a single uid, and a namespace with an existing
        //      linkedUserId is immutable (see namespaces create/update above).
        //
        //   2. Existing owner/admin adds another member. Role cannot be
        //      elevated to 'owner' except by an existing owner.
        allow create: if request.auth != null && (
          (memberId == request.auth.uid
            && request.resource.data.role == 'owner'
            && get(/databases/$(database)/documents/namespaces/$(handle)).data.linkedUserId == request.auth.uid)
          || (get(/databases/$(database)/documents/namespaces/$(handle)/members/$(request.auth.uid)).data.role in ['owner', 'admin']
              && (request.resource.data.role != 'owner'
                  || get(/databases/$(database)/documents/namespaces/$(handle)/members/$(request.auth.uid)).data.role == 'owner'))
        );
        allow update: if request.auth != null
          && get(/databases/$(database)/documents/namespaces/$(handle)/members/$(request.auth.uid)).data.role in ['owner', 'admin']
          && (request.resource.data.role != 'owner'
              || get(/databases/$(database)/documents/namespaces/$(handle)/members/$(request.auth.uid)).data.role == 'owner');
        // Owner/admin can remove any member; any member may remove themselves (leave).
        allow delete: if request.auth != null
          && (get(/databases/$(database)/documents/namespaces/$(handle)/members/$(request.auth.uid)).data.role in ['owner', 'admin']
              || request.auth.uid == memberId);
      }

      // Workflow secrets: only namespace members (server actions enforce this via Admin SDK;
      // these rules are defense-in-depth for client SDK access)
      match /workflowSecrets/{workflowName} {
        allow read: if request.auth != null
          && exists(/databases/$(database)/documents/namespaces/$(handle)/members/$(request.auth.uid));
        allow create, update: if request.auth != null
          && exists(/databases/$(database)/documents/namespaces/$(handle)/members/$(request.auth.uid));
        allow delete: if false;
      }
    }

    // Users: read by authenticated, write by authenticated (org admins add to organizations[])
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // Workflow definitions: read by authenticated, write by authenticated
    match /workflowDefinitions/{defId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    match /workflowMeta/{metaId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    match /humanTasks/{taskId} {
      // Read: user with matching role can see the task queue
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles
           .hasAny([resource.data.assignedRole]);
      // Create: engine creates tasks (any authenticated user acting as system)
      allow create: if request.auth != null;
      // Update: claim, complete, cancel operations
      allow update: if request.auth != null;
      allow delete: if false;
    }

    match /handoffEntities/{entityId} {
      // Read: user with matching role can see the handoff
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles
           .hasAny([resource.data.assignedRole]);
      // Create: agent runtime creates handoffs
      allow create: if request.auth != null;
      // Update: only the user who claimed it (assignedUserId) can acknowledge/resolve
      allow update: if request.auth != null
        && request.auth.uid == resource.data.assignedUserId;
      allow delete: if false;
    }

    // Agent runs: read and write by any authenticated user (BUG-02 fix — client SDK writes from FirestoreAgentRunRepository)
    match /agentRuns/{runId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // Process instances: any authenticated read (BUG-03 fix — role-scoped read deferred to Phase 6)
    // Authenticated writes: platform-ui API routes use client SDK to create/update instances
    match /processInstances/{instanceId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;  // platform-ui API routes use client SDK
      allow delete: if false;

      // Step executions: any authenticated read/write (platform-ui API routes use client SDK)
      match /stepExecutions/{execId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null;
        allow delete: if false;
      }

      // Agent events: any authenticated read/write (platform-ui API routes use client SDK)
      match /agentEvents/{eventId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null;
        allow delete: if false;
      }
    }
  }
}
