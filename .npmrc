shamefully-hoist=false
strict-peer-dependencies=true

# Supply-chain protection: don't install packages published less than 7 days ago
minimum-release-age=10080
# Security-fix exemptions — only packages whose patched version is <7 days old.
# Check an entry's publish age before removing:
#   npm view <pkg>@<ver> time --json | jq -r ".[\"<ver>\"]"
# e.g. npm view protobufjs@7.5.5 time --json | jq -r '.["7.5.5"]'
# If the date is >7 days old, drop the entry from both this file and package.json.
minimum-release-age-exclude[]=axios
# protobufjs@7.5.5 exempt: security fix for GHSA-xq3m-2v4x-88gg (Critical, CVSS 9.4)
minimum-release-age-exclude[]=protobufjs
minimum-release-age-exclude[]=hono
